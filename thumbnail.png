  <!-- Panel title -->
  <text x="520" y="100" text-anchor="middle" font-family="Georgia, serif" font-size="13" font-style="italic" fill="#c8914a" opacity="0.9" style="fill:rgb(200, 145, 74);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:Georgia, serif;font-size:13px;font-weight:400;font-style:italic;text-anchor:middle;dominant-baseline:auto">— filters —</text>

  <!-- Filter chips -->
